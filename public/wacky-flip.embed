<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Wacky Flip</title>
  <style>
    html, body {
      width: 100%;
      height: 100%;
      margin: 0;
      padding: 0;
      overflow: hidden;
      background-color: #000;
    }
    iframe {
      width: 100%;
      height: 100%;
      border: none;
      display: block;
    }
  </style>
</head>
<body>
  <iframe 
    id="iframehtml5" 
    title="Wacky Flip" 
    src="https://game.azgame.io/wacky-flip/" 
    allowfullscreen="true" 
    scrolling="no"
    allow="autoplay; fullscreen; gamepad; keyboard-map *; accelerometer; gyroscope; clipboard-write; web-share; magnetometer; camera; focus-without-user-activation *; monetization; xr-spatial-tracking; display-capture"
  ></iframe>
</body>
</html>
