<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Runaway Toad</title>
  <style>
    html, body {
      width: 100%;
      height: 100%;
      margin: 0;
      padding: 0;
      overflow: hidden;
      background-color: #000;
    }
    iframe {
      width: 100%;
      height: 100%;
      border: none;
      display: block;
    }
  </style>
</head>
<body>
  <iframe 
    id="html5game" 
    title="Runaway Toad" 
    src="https://play.gamepix.com/runaway-toad/embed?sid=6HLOM" 
    allowfullscreen="true" 
    scrolling="no"
    allow="autoplay; fullscreen; gamepad; keyboard-map *; accelerometer; gyroscope; clipboard-write; web-share; microphone"
  ></iframe>
</body>
</html>
